{
  "name": "portfolio-website",
  "version": "3.0.0",
  "description": "Personal portfolio website with full backend + Vue 3 frontend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:server": "nodemon server.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm install --prefix frontend && npm run build --prefix frontend",
    "postinstall": "npm install --prefix frontend",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
